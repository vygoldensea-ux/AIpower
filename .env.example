# ============================================================
# AI Social Manager — Environment Variables Reference
# Set all of these in Railway dashboard → Variables tab
# NEVER put real keys here — this file is committed to git
# ============================================================

# ---- Supabase (REQUIRED) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- AI (REQUIRED) ----
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# ---- Telegram (REQUIRED) ----
TELEGRAM_BOT_TOKEN=1234567890:AAF...
# Any random string — must match what you set in Telegram webhook
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# ---- Ayrshare (REQUIRED for social posting) ----
AYRSHARE_API_KEY=your_ayrshare_key

# ---- Free image sources (OPTIONAL) ----
UNSPLASH_ACCESS_KEY=your_unsplash_client_id
PEXELS_API_KEY=your_pexels_key

# ---- Zalo OA (OPTIONAL) ----
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_OA_ACCESS_TOKEN=

# ---- Facebook Analytics (OPTIONAL) ----
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ---- Redis / Upstash (OPTIONAL — future BullMQ queue) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Internal ----
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_32char_hex_secret
INTERNAL_TELEGRAM_CHAT_ID=your_telegram_chat_id_for_alerts
AGENCY_NAME=GoldenSea Studios
# Set to your Railway public URL after first deploy
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
